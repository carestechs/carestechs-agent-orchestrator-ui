# Copy to .env (gitignored) before running `docker compose -f docker-compose.prod.yml up`.
#
# These three values are passed to the Dockerfile as --build-args. They end up
# baked into the bundle AND in the image's `docker history` layer metadata.
# Acceptable under the interim network-gated posture; see
# docs/ARCHITECTURE.md § "Interim security posture" before pushing images to a
# shared registry.

ORCHESTRATOR_BASE_URL=http://127.0.0.1:8000
ORCHESTRATOR_API_KEY=replace-me
OPERATOR_PASSPHRASE=replace-me
